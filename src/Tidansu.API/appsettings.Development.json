{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "TidansuDb": "Server=(localdb)\\MSSQLLocalDB;Database=TidansuDb;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "AppSettings": {
    "FrontendUrl": "http://localhost:5173"
  },
  "JwtSettings": {
    "Secret": "DevSecretKeyForLocalDevelopmentOnlyAtLeast32Chars!",
    "Issuer": "TidansuAPI",
    "Audience": "TidansuApp",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "SmtpSettings": {
    "Host": "localhost",
    "Port": "25",
    "SenderEmail": "noreply@tidansu.local",
    "SenderName": "Tidansu Development"
  },
  "StripeSettings": {
    "Enabled": false,
    "SecretKey": "",
    "WebhookSecret": "",
    "ProPriceId": "",
    "SuccessUrl": "http://localhost:5173/account?upgraded=1",
    "CancelUrl": "http://localhost:5173/pricing"
  },
  "Serilog": {
    "MinimumLevel": {
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:dd-MM HH:mm:ss} {Level:u3}] |{SourceContext}| {NewLine}{Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  }
}
