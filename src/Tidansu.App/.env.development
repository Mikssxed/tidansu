# Loaded only in dev mode (`vite dev` / `npm run dev`), never by `vite build`.
# Bypasses route auth guards so devs can navigate without signing in. Never affects prod.
VITE_DISABLE_AUTH=true

# Pre-Checkout consumer-law consent step (FR-11). Default OFF: an upgrade goes
# straight to the billing seam. Set to `true` to route upgrades through
# CheckoutConsentStep (disclosures + withdrawal-waiver consent + "Subscribe & pay").
# VITE_CHECKOUT_CONSENT=true
